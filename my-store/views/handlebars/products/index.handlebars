{{!-- handlebars/products/index.handlebars --}}
<div class="container">
    <div class="page-header">
        <h1 class="page-title">Каталог товарів</h1>
        {{#if user}}
        <a href="/products/add" class="btn">+ Додати товар</a>
        {{/if}}
    </div>

    <div class="filters">
        <a href="/products" class="filter-btn {{#unless currentCategory}}active{{/unless}}">Всі</a>
        <a href="/products?category=electronics" class="filter-btn {{#ifEquals currentCategory 'electronics'}}active{{/ifEquals}}">Електроніка</a>
        <a href="/products?category=clothing" class="filter-btn {{#ifEquals currentCategory 'clothing'}}active{{/ifEquals}}">Одяг</a>
    </div>

    {{#if products}}
    <div class="products-grid">
        {{#each products}}
        <div class="product-card">
            <div class="product-image">
                {{#if this.image}}
                <img src="{{this.image}}" alt="{{this.name}}">
                {{else}}
                📦
                {{/if}}
            </div>
            <div class="product-info">
                <h3 class="product-name">{{this.name}}</h3>
                <p class="product-description">{{truncate this.description 80}}</p>
                <div class="product-price">
                    {{formatPrice this.price}}
                </div>
            </div>
        </div>
        {{/each}}
    </div>
    {{else}}
    <div class="no-products">
        <p>Товари не знайдено</p>
    </div>
    {{/if}}
</div>