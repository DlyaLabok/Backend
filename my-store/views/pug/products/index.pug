//- products/index.pug - Каталог товарів
//- Демонструє: Pug filters, each...in з індексом, forms

extends ../layout

block content
    .container
        .page-header
            h1.page-title Каталог товарів

            //- Add product button
            if user && user.role === 'admin'
                a.btn(href="/products/add") + Додати товар

        //- Category filter
        .filters
            a.filter-btn(href="/products" class=!currentCategory ? 'active' : '') Всі
            each cat in [{name: 'electronics', label: 'Електроніка'}, {name: 'clothing', label: 'Одяг'}, {name: 'books', label: 'Книги'}]
                a.filter-btn(href="/products?category=" + cat.name class=currentCategory === cat.name ? 'active' : '')
                    = cat.label

        //- Products list
        if !products || products.length === 0
            .no-products
                .empty-state
                    span.empty-icon 📦
                    h2 Товари не знайдено
                    p Каталог порожній. Додайте перший товар!
                    if user
                        a.btn(href="/products/add") + Додати товар
        else
            .products-grid
                each product, index in products
                    .product-card(class=index % 2 === 0 ? 'even' : 'odd')
                        .product-image
                            if product.image
                                img(src=product.image, alt=product.name)
                            else
                                .product-placeholder 📦
                        .product-info
                            h3.product-name= product.name
                            if product.description
                                p.product-description= product.description
                            .product-meta
                                span.product-price
                                    | #{new Intl.NumberFormat('uk-UA', {style: 'currency', currency: 'UAH'}).format(product.price)}
                                span.product-stock
                                    | В наявності: #{product.stock || 0}
                            .product-actions
                                a.btn.btn-sm(href="/products/" + product.id) ✏️ Редагувати
                                form(action="/products/delete/" + product.id method="POST" onsubmit="return confirm('Видалити?')")
                                    button.btn.btn-sm.btn-danger(type="submit") 🗑️ Видалити

        //- Pagination placeholder
        .pagination
            span.pagination-info Показано #{products ? products.length : 0} товарів