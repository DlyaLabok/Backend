<!DOCTYPE html>
<html lang="uk">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= title %></title>
    <link rel="stylesheet" href="/public/css/style.css">
</head>
<body class="auth-page">
    <div class="auth-container">
        <div class="auth-card">
            <div class="auth-header">
                <h1 class="auth-logo">📝 Реєстрація</h1>
                <p class="auth-subtitle">Створіть новий обліковий запис</p>
            </div>

            <% if (error) { %>
                <div class="alert alert-error"><%= error %></div>
            <% } %>

            <form action="/auth/signup" method="POST" class="auth-form" onsubmit="return validateForm()">
                <div class="form-group">
                    <label for="name">Ім'я</label>
                    <input type="text" id="name" name="name" required placeholder="Ваше ім'я">
                </div>

                <div class="form-group">
                    <label for="email">Email</label>
                    <input type="email" id="email" name="email" required placeholder="email@example.com">
                </div>

                <div class="form-group">
                    <label for="password">Пароль</label>
                    <input type="password" id="password" name="password" required minlength="6" placeholder="Мінімум 6 символів">
                </div>

                <div class="form-group">
                    <label for="confirmPassword">Підтвердження пароля</label>
                    <input type="password" id="confirmPassword" name="confirmPassword" required placeholder="Повторіть пароль">
                </div>

                <button type="submit" class="btn btn-block">Зареєструватися</button>
            </form>

            <div class="auth-footer">
                <p>Вже є акаунт? <a href="/auth/login">Увійти</a></p>
            </div>
        </div>
    </div>

    <script>
        function validateForm() {
            const password = document.getElementById('password').value;
            const confirm = document.getElementById('confirmPassword').value;

            if (password !== confirm) {
                alert('Паролі не співпадають!');
                return false;
            }

            if (password.length < 6) {
                alert('Пароль має бути мінімум 6 символів!');
                return false;
            }

            return true;
        }
    </script>
</body>
</html>