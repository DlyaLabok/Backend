<!DOCTYPE html>
<html lang="uk">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= title %></title>
    <link rel="stylesheet" href="/public/css/style.css">
</head>
<body class="auth-page">
    <div class="auth-container">
        <div class="auth-card">
            <div class="auth-header">
                <h1 class="auth-logo">🔐 Auth System</h1>
                <p class="auth-subtitle">Вхід до системи</p>
            </div>

            <% if (error) { %>
                <div class="alert alert-error"><%= error %></div>
            <% } %>

            <form action="/auth/login" method="POST" class="auth-form">
                <div class="form-group">
                    <label for="email">Email</label>
                    <input type="email" id="email" name="email" required placeholder="email@example.com">
                </div>

                <div class="form-group">
                    <label for="password">Пароль</label>
                    <input type="password" id="password" name="password" required placeholder="Ваш пароль">
                </div>

                <div class="form-group form-check">
                    <input type="checkbox" id="rememberMe" name="rememberMe" value="1">
                    <label for="rememberMe">Запам'ятати мене (JWT)</label>
                </div>

                <button type="submit" class="btn btn-block">Увійти</button>
            </form>

            <div class="auth-footer">
                <p>Немає акаунту? <a href="/auth/signup">Зареєструватися</a></p>
            </div>

            <div class="auth-demo">
                <p>Демо-доступ:</p>
                <code>admin@auth.com / password123</code>
            </div>
        </div>
    </div>
</body>
</html>